{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023"],
    "module": "esnext",
    "types": ["node"],
    "skipLibCheck": true,
    "paths": {
      "@obel-arg/malbec-ui": ["./lib/main.ts"],
      "@obel-arg/malbec-ui/icons": ["./lib/icons/index.ts"],
      "@obel-arg/malbec-ui/icons/custom": ["./lib/icons/custom-barrel.ts"],
      "malbec-ui": ["./lib/main.ts"],
      "malbec-ui/icons": ["./lib/icons/index.ts"],
      "malbec-ui/icons/custom": ["./lib/icons/custom-barrel.ts"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["vite.config.ts"]
}
